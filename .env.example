# Canonical site URL (RSS, sitemap, Open Graph)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Tina Cloud — optional for local-only editing; required for production admin
# See https://tina.io/docs/tina-cloud/overview
# NEXT_PUBLIC_TINA_CLIENT_ID=
# TINA_TOKEN=
# Branch for Tina Cloud (must exist in your Tina project → Configuration → branches).
# Netlify sets BRANCH automatically. Locally, tina/config.ts also uses `git rev-parse`.
# BRANCH=main
